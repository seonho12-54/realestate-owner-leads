NODE_ENV=development
APP_BASE_URL=http://localhost:3000

DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=3306
DB_NAME=realestate_leads
DB_USER=app_user
DB_PASSWORD=change-me
DATABASE_URL=mysql://app_user:change-me@your-rds-endpoint.amazonaws.com:3306/realestate_leads

S3_BUCKET=your-owner-leads-bucket
S3_REGION=ap-northeast-2
S3_UPLOAD_PREFIX=leads

ADMIN_SESSION_SECRET=replace-with-a-long-random-string
USER_SESSION_SECRET=replace-with-another-long-random-string
KAKAO_REST_API_KEY=replace-with-your-kakao-rest-api-key
NEXT_PUBLIC_KAKAO_JS_KEY=replace-with-your-kakao-javascript-key
MAX_PHOTO_SIZE_MB=20
MAX_PHOTO_COUNT=10
